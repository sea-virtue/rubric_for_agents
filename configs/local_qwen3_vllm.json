{
  "input": "data/agent-reward-bench/trajectories",
  "input_format": "agent_reward_bench",
  "max_input_records": 5,
  "agent_reward_observation_chars": 300,
  "agent_reward_observation_policy": "last",
  "out_dir": "outputs/local_qwen3_vllm",
  "api_key_env": "OPENAI_API_KEY",
  "base_url": "http://127.0.0.1:8000/v1",
  "rubric_models": [
    "qwen3-4b-instruct-2507"
  ],
  "merge_model": "qwen3-4b-instruct-2507",
  "embedding_model": "",
  "min_model_support": 1,
  "concurrency": 1,
  "cluster_algorithm": "connected",
  "cluster_partition_metadata_keys": [
    "benchmark",
    "task_family"
  ],
  "cluster_threshold": 0.34,
  "min_cluster_size": 2,
  "generalization_threshold": 0.74,
  "max_records_per_cluster": 2,
  "max_chars_per_trace": 1500,
  "llm_max_tokens": 1024
}
