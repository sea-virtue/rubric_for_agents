{
  "input": "data/agent_steps.csv",
  "input_format": "csv",
  "csv_group_by": "trace_id",
  "field_map": {
    "__record_id__": "trace_id",
    "task": "task",
    "outcome": "success"
  },
  "out_dir": "outputs/csv_multirow_task",
  "rubric_models": [
    "gpt-4.1-mini",
    "gpt-4.1",
    "gpt-4.1-mini"
  ],
  "merge_model": "gpt-4.1",
  "embedding_model": "text-embedding-3-small",
  "min_model_support": 2,
  "concurrency": 4,
  "cluster_threshold": 0.74,
  "max_records_per_cluster": 20
}
