{
  "input": "data/agent-reward-bench/trajectories",
  "input_format": "agent_reward_bench",
  "agent_reward_observation_chars": 500,
  "agent_reward_observation_policy": "last_and_errors",
  "out_dir": "outputs/local_qwen3_vllm_qwen3_embedding_full",
  "api_key_env": "OPENAI_API_KEY",
  "base_url": "http://127.0.0.1:8000/v1",
  "embedding_api_key_env": "OPENAI_API_KEY",
  "embedding_base_url": "http://127.0.0.1:8001/v1",
  "embedding_instruction": "Represent this agent trajectory for clustering by task intent, website/domain, agent strategy, tool/action sequence, observation feedback, error recovery, and success/failure behavior.",
  "embedding_max_chars": 20000,
  "embedding_batch_size": 16,
  "rubric_models": [
    "qwen3-4b-instruct-2507"
  ],
  "merge_model": "qwen3-4b-instruct-2507",
  "embedding_model": "qwen3-embedding-8b",
  "min_model_support": 1,
  "concurrency": 1,
  "cluster_algorithm": "dbscan",
  "cluster_partition_metadata_keys": [
    "benchmark",
    "agent",
    "experiment",
    "task_family"
  ],
  "cluster_threshold": 0.76,
  "min_cluster_size": 2,
  "generalization_threshold": 0.78,
  "max_records_per_cluster": 8,
  "max_chars_per_trace": 10000,
  "mining_prompt_token_budget": 26000,
  "llm_max_tokens": 4096
}
